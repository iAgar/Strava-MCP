# Strava API Credentials
STRAVA_CLIENT_ID=your_client_id
STRAVA_CLIENT_SECRET=your_client_secret

# OAuth Configuration
# This should match your Cloudflare Worker URL (e.g., https://strava-mcp.your-subdomain.workers.dev)
AUTH_CALLBACK_DOMAIN=http://localhost:8788

# Cloudflare Configuration
# Only used for local development with .dev.vars
CLOUDFLARE_ACCOUNT_ID=your_account_id
OAUTH_KV_ID=your_kv_namespace_id
